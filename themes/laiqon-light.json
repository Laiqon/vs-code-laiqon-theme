{
    "$schema": "vscode://schemas/color-theme",
    "name": "Laiqon Light",
    "type": "light",
    "include": "./base/light_plus.json",
    "colors": {
        // Title bar
        "titleBar.activeBackground": "#EBEBED",
        "titleBar.inactiveBackground": "#EBEBED",
        "titleBar.border": "#D1D1D6",
        // Activity bar icons
        "activityBar.border": "#D1D1D6",
        "activityBar.background": "#EBEBED",
        "activityBar.foreground": "#FF8C42", // primary
        "activityBar.inactiveForeground": "#6C6C70",
        "activityBar.activeBorder": "#FF8C42", // primary
        "activityBarBadge.background": "#FF8C42", // primary
        "activityBarBadge.foreground": "#FFFFFF",
        // Breadcrumb path
        "breadcrumb.background": "#F5F5F7",
        "breadcrumb.foreground": "#6C6C70",
        "breadcrumb.focusForeground": "#FF8C42", // primary
        "breadcrumb.activeSelectionForeground": "#FF8C42", // primary
        // Sidebar (Explorer, etc.)
        "sideBar.background": "#FDFDFF",
        "sideBar.border": "#D1D1D6",
        "sideBarSectionHeader.border": "#D1D1D6",
        // Tabs
        "tab.activeBackground": "#F5F5F7",
        "tab.activeForeground": "#FF8C42", // primary
        "tab.activeBorderTop": "#FF8C42", // primary
        "tab.inactiveBackground": "#EBEBED",
        "tab.inactiveForeground": "#6C6C70",
        "tab.hoverBackground": "#E5E5E7",
        "tab.border": "#D1D1D6",
        // Code editor
        "editor.background": "#f5f7fc",
        "editor.foreground": "#1D1D1F",
        "editor.selectionBackground": "#FF8C4226",
        "editor.selectionHighlightBackground": "#FF8C4212",
        "editor.findMatchBackground": "#FF8C424D",
        "editor.findMatchHighlightBackground": "#FF8C421A",
        "editor.wordHighlightBackground": "#FF8C420F",
        "editorCursor.foreground": "#FF8C42", // primary
        // Borders between editors (tabs)
        "editorGroup.border": "#D1D1D6",
        "editorGroupHeader.border": "#00000000",
        "editorGroupHeader.tabsBackground": "#EBEBED",
        // Bottom panel (Terminal, Problems, Output, etc.)
        "panel.background": "#EBEBED", // --depth
        "panel.border": "#D1D1D6",
        // Bottom status bar
        "statusBar.background": "#EBEBED",
        "statusBar.border": "#D1D1D6",
        "statusBar.foreground": "#6C6C70",
        "statusBar.noFolderBackground": "#EBEBED",
        "statusBar.debuggingBackground": "#FF8C42", // primary
        "statusBar.debuggingForeground": "#FFFFFF",
        // Lists (File Explorer, etc.)
        "list.hoverBackground": "#E5E5E7",
        "list.activeSelectionBackground": "#FF8C4260", // primary
        "list.inactiveSelectionBackground": "#FF8C4230", // primary
        "list.focusBackground": "#E8E8EA",
        // Scrollbars
        "scrollbarSlider.background": "#FF8C4230", // primary
        "scrollbarSlider.hoverBackground": "#FF8C4260", // primary
        "scrollbarSlider.activeBackground": "#FF8C4280", // primary
        // Buttons
        "button.background": "#FF8C42", // primary
        "button.foreground": "#FFFFFF",
        "dropdown.background": "#FFFFFF",
        "input.background": "#FFFFFF",
        "textLink.foreground": "#1B76D1",
        "focusBorder": "#00000000"
    },
    "tokenColors": [
        // ─── COMMENTS ────────────────────────────────────────────────
        {
            "name": "Comments",
            "scope": [
                "comment",
                "comment.block",
                "comment.line",
                "comment.block.documentation",
                "punctuation.definition.comment"
            ],
            "settings": {
                "foreground": "#4F9272",
                "fontStyle": "italic"
            }
        },
        // ─── KEYWORDS ────────────────────────────────────────────────
        {
            "name": "Keywords",
            "scope": [
                "keyword",
                "keyword.control",
                "keyword.control.flow",
                "keyword.operator.new",
                "keyword.other.using",
                "keyword.other.var",
                "storage.modifier",
                "storage.type.class",
                "storage.type.interface",
                "storage.type.enum"
            ],
            "settings": {
                "foreground": "#C28A5F" //primary - middle point — saturation −35%, brightness −10%
            }
        },
        // ─── TYPES / CLASSES / INTERFACES ────────────────────────────
        {
            "name": "Types, Classes, Interfaces",
            "scope": [
                "entity.name.type",
                "entity.name.class",
                "entity.name.interface",
                "entity.name.enum",
                "support.class",
                "support.type",
                "storage.type.primitive"
            ],
            "settings": {
                "foreground": "#4EC9B0"
            }
        },
        // ─── FUNCTIONS / METHODS ─────────────────────────────────────
        {
            "name": "Functions and Methods",
            "scope": [
                "entity.name.function",
                "support.function",
                "meta.function-call entity.name.function"
            ],
            "settings": {
                "foreground": "#DDBF6F",
                "fontStyle": "italic"
            }
        },
        // ─── NAMESPACES ───────────────────────────────────────────────
        {
            "name": "Namespaces",
            "scope": [
                "entity.name.namespace",
                "entity.name.type.namespace",
                "storage.type.namespace"
            ],
            "settings": {
                "foreground": "#A87860", //primary - saturation −55%, very soft
                "fontStyle": "italic"
            }
        },
        // ─── STRINGS ─────────────────────────────────────────────────
        {
            "name": "Strings",
            "scope": [
                "string",
                "string.quoted",
                "string.template"
            ],
            "settings": {
                "foreground": "#ce7b78",
                "fontStyle": "italic"
            }
        },
        // ─── STRING INTERPOLATION ─────────────────────────────────────
        {
            "name": "String interpolation / template expression",
            "scope": [
                "meta.interpolation",
                "punctuation.definition.template-expression",
                "string.template meta.template.expression"
            ],
            "settings": {
                "foreground": "#D4956A",
                "fontStyle": ""
            }
        },
        // ─── PARAMETERS ──────────────────────────────────────────────
        {
            "name": "Parameters",
            "scope": [
                "variable.parameter",
                "meta.function.parameters variable.other"
            ],
            "settings": {
                "foreground": "#D4D7DC"
            }
        },
        // ─── PROPERTIES ──────────────────────────────────────────────
        {
            "name": "Properties and fields",
            "scope": [
                "variable.other.property",
                "variable.other.object.property",
                "support.variable.property",
                "meta.object-literal.key",
                "entity.name.variable.field"
            ],
            "settings": {
                "foreground": "#9CDCFE"
            }
        },
        // ─── VARIABLES ───────────────────────────────────────────────
        {
            "name": "Variables",
            "scope": [
                "variable",
                "variable.other",
                "variable.other.readwrite"
            ],
            "settings": {
                "foreground": "#D4D7DC"
            }
        },
        // ─── NUMBERS / BOOLEANS ──────────────────────────────────────
        {
            "name": "Numbers and booleans",
            "scope": [
                "constant.numeric",
                "constant.language.boolean",
                "constant.language.null",
                "constant.language.undefined",
                "constant.language"
            ],
            "settings": {
                "foreground": "#6DB88A"
            }
        },
        // ─── ATTRIBUTES (C# / decorators) ────────────────────────────
        {
            "name": "Attributes and decorators",
            "scope": [
                "entity.name.type.attribute",
                "storage.type.attribute",
                "meta.attribute entity.name.function",
                "punctuation.decorator",
                "meta.decorator entity.name.function",
                "meta.decorator variable.other"
            ],
            "settings": {
                "foreground": "#C586C0"
            }
        },
        // ─── JSX TAGS (html elements) ────────────────────────────────
        {
            "name": "JSX/TSX — HTML tags",
            "scope": [
                "entity.name.tag",
                "support.class.component",
                "punctuation.definition.tag"
            ],
            "settings": {
                "foreground": "#4EC9B0"
            }
        },
        // ─── JSX ATTRIBUTES ──────────────────────────────────────────
        {
            "name": "JSX/TSX — attributes",
            "scope": [
                "entity.other.attribute-name",
                "meta.jsx.children entity.other.attribute-name"
            ],
            "settings": {
                "foreground": "#C586C0"
            }
        },
        // ─── ENUM MEMBERS ─────────────────────────────────────────────
        {
            "name": "Enum members",
            "scope": [
                "variable.other.enummember"
            ],
            "settings": {
                "foreground": "#6DB88A",
                "fontStyle": "italic"
            }
        },
        // ─── PUNCTUATION ─────────────────────────────────────────────
        {
            "name": "Punctuation",
            "scope": [
                "punctuation",
                "meta.brace",
                "punctuation.separator",
                "punctuation.terminator"
            ],
            "settings": {
                "foreground": "#4A4A4F"
            }
        },
        // ─── OPERATORS ───────────────────────────────────────────────
        {
            "name": "Operators",
            "scope": [
                "keyword.operator",
                "storage.type.function.arrow"
            ],
            "settings": {
                "foreground": "#C586C0"
            }
        }
    ]
}
