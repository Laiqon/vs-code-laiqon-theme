{
    "$schema": "vscode://schemas/color-theme",
    "name": "Laiqon Carbon",
    "type": "dark",
    "include": "./base/dark_plus.json",
    "colors": {
        // Title bar
        "titleBar.activeBackground": "#0F1115",
        "titleBar.inactiveBackground": "#0F1115",
        "titleBar.border": "#0F1115",
        // Activity bar icons
        "activityBar.border": "#0F1115",
        "activityBar.background": "#0F1115",
        "activityBar.foreground": "#7cb518", // primary
        "activityBar.inactiveForeground": "#D6DAE0",
        "activityBar.activeBorder": "#7cb518", // primary
        "activityBarBadge.background": "#7cb518", // primary
        "activityBarBadge.foreground": "#FFFFFF",
        // Breadcrumb path
        "breadcrumb.background": "#252527",
        "breadcrumb.foreground": "#6C727F",
        "breadcrumb.focusForeground": "#7cb518", // primary
        "breadcrumb.activeSelectionForeground": "#7cb518", // primary
        // Sidebar (Explorer, etc.)
        "sideBar.background": "#252527",
        "sideBar.border": "#0F1115",
        "sideBarSectionHeader.border": "#0F1115",
        // Tabs
        "tab.activeBackground": "#252527",
        "tab.activeForeground": "#7cb518", // primary
        "tab.activeBorderTop": "#7cb518", // primary
        "tab.inactiveBackground": "#1A1A1C",
        "tab.inactiveForeground": "#9AA3AD",
        "tab.hoverBackground": "#2C2C2E",
        "tab.border": "#0F1115",
        // Code editor
        "editor.background": "#151517",
        "editor.foreground": "#D6DAE0",
        "editor.selectionBackground": "#7cb51840",
        "editor.selectionHighlightBackground": "#7cb51820",
        "editor.findMatchBackground": "#7cb51859",
        "editor.findMatchHighlightBackground": "#7cb51820",
        "editor.wordHighlightBackground": "#7cb5181A",
        "editorCursor.foreground": "#7cb518", // primary
        // Borders between editors (tabs)
        "editorGroup.border": "#252527",
        "editorGroupHeader.border": "#00000000",
        "editorGroupHeader.tabsBackground": "#00000000",
        // Bottom panel (Terminal, Problems, Output, etc.)
        "panel.background": "#141416", // darker than --depth
        "panel.border": "#252527",
        // Bottom status bar
        "statusBar.background": "#0F1115",
        "statusBar.border": "#20232A",
        "statusBar.foreground": "#D6DAE0",
        "statusBar.noFolderBackground": "#0F1115",
        "statusBar.debuggingBackground": "#7cb518", // primary
        "statusBar.debuggingForeground": "#1C2027", // secondary
        // Lists (File Explorer, etc.)
        "list.hoverBackground": "#0F1115",
        "list.activeSelectionBackground": "#7cb51850", // primary
        "list.inactiveSelectionBackground": "#7cb51820", // primary
        "list.focusBackground": "#252527",
        // Scrollbars
        "scrollbarSlider.background": "#7cb51890", // primary
        "scrollbarSlider.hoverBackground": "#7cb51850", // primary
        "scrollbarSlider.activeBackground": "#7cb51880", // primary
        // Buttons
        "button.background": "#7cb51850", // primary
        "button.foreground": "#FFFFFF",
        "dropdown.background": "#0F1115",
        "input.background": "#0F1115",
        "textLink.foreground": "#67B5FF",
        "focusBorder": "#00000000"
    },
    "tokenColors": [
        {
            "name": "Comments (all)",
            "scope": [
                "comment",
                "comment.block",
                "comment.line",
                "comment.block.documentation",
                "comment.line.documentation"
            ],
            "settings": {
                "foreground": "#4F9272",
                "fontStyle": "italic"
            }
        },
        {
            "name": "Strings",
            "scope": "string",
            "settings": {
                "foreground": "#F29191",
                "fontStyle": "italic"
            }
        },
        {
            "name": "Control Keywords",
            "scope": [
                "keyword.control",
                "keyword.control.flow"
            ],
            "settings": {
                "foreground": "#9184EE"
            }
        },
        {
            "name": "Methods",
            "scope": [
                "entity.name.function",
                "support.function"
            ],
            "settings": {
                "foreground": "#FFDE9D",
                "fontStyle": "italic"
            }
        },
        {
            "name": "Namespaces",
            "scope": [
                "entity.name.namespace",
                "storage.type.namespace"
            ],
            "settings": {
                "foreground": "#7B8188"
            }
        },
        {
            "name": "Enum Members",
            "scope": [
                "variable.other.enummember"
            ],
            "settings": {
                "fontStyle": "italic"
            }
        }
    ]
}
